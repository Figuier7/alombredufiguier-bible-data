{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Figuier7/alombredufiguier-bible-data/schemas/greek-strong-entry.schema.json",
  "title": "Greek Strong French Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "strong",
    "lemma",
    "translit",
    "gloss_fr",
    "definition_fr",
    "derivation_fr",
    "status",
    "source"
  ],
  "properties": {
    "strong": {
      "type": "string",
      "pattern": "^G[0-9]+$"
    },
    "lemma": {
      "type": "string",
      "minLength": 1
    },
    "translit": {
      "type": "string",
      "minLength": 1
    },
    "gloss_fr": {
      "type": "string",
      "minLength": 1
    },
    "definition_fr": {
      "type": "string",
      "minLength": 1
    },
    "derivation_fr": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "const": "curated"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original_work",
        "author",
        "year",
        "license",
        "basis",
        "translation"
      ],
      "properties": {
        "original_work": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "year": {
          "type": "integer",
          "const": 1890
        },
        "license": {
          "const": "Public Domain"
        },
        "basis": {
          "type": "string",
          "minLength": 1
        },
        "translation": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
